# Application
ENVIRONMENT=development
DEBUG=true

# Admin
ADMIN_USER=admin
ADMIN_PASS=change_this_password

# API Keys
FIXER_API_KEY=your_fixer_api_key

# Database (SQLite usado localmente por padrao)
DATABASE_URL=acessos.db

# Email (for reports)
EMAIL_REMETENTE=your_email@gmail.com
EMAIL_SENHA=your_app_password
SMTP_SERVIDOR=smtp.gmail.com
SMTP_PORTA=587

# Frontend -> Backend connection (usado pelo Streamlit)
API_URL=http://localhost:8000

# CORS - origens extras separadas por virgula (para deploy)
# Ex: CORS_EXTRA_ORIGINS=https://meu-frontend.streamlit.app,https://outro-dominio.com
CORS_EXTRA_ORIGINS=
